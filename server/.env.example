# WhatsApp order redirect
OWNER_WHATSAPP_NUMBER=46728448929

# Telegram Bot (create via @BotFather, then set domain with /setdomain)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram user ID of the admin (find your ID via @userinfobot)
ADMIN_TELEGRAM_ID=your_telegram_id_here

# JWT secret — change to a long random string in production
JWT_SECRET=change_me_to_a_long_random_secret

# Frontend URL for CORS (optional)
FRONTEND_URL=
